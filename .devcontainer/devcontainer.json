// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/alpine
{
	"name": "WaterDetectImage",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "cordmaur/planetary:v4",
	"mounts": [
		// if running Local Windows
		// "source=D:/OneDrive/data,target=/data,type=bind",
		"source=${localEnv:VULNERABILITY_FOLDER},target=/data,type=bind",
	],
	"runArgs": [
		"--memory=50g",
		"--memory-swap=50g",
		"--oom-kill-disable"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-toolsai.jupyter",
				"ms-azuretools.vscode-docker",
				"ms-toolsai.vscode-jupyter-cell-tags",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff",
				"njpwerner.autodocstring",
				"tamasfe.even-better-toml"
			]
		}
	},
	"postCreateCommand": "pip install -e . --break-system-packages",
	// "postCreateCommand": "pip install scikit-learn==1.2.2; pip install -e /workspaces/Sentinel1-Flood-Finder/.",
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "uname -a",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}